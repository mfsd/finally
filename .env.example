# FinAlly runtime configuration

# OpenRouter enables the LLM chat assistant. Leave empty with LLM_MOCK=true for local smoke tests.
OPENROUTER_API_KEY=

# Optional: Massive/Polygon-compatible market data. Empty uses the built-in simulator.
MASSIVE_API_KEY=

# free_eod uses real Massive end-of-day closes plus simulated intraday variation.
# snapshot requires a paid plan with stock snapshot access.
MASSIVE_MODE=free_eod

# Use deterministic mock LLM responses for local testing and E2E runs.
LLM_MOCK=true

# Optional host port for scripts and docker compose.
FINALLY_PORT=8000
